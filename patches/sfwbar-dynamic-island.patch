diff --git a/src/gui/popup.c b/src/gui/popup.c
index 1601f3f..e76377d 100644
--- a/src/gui/popup.c
+++ b/src/gui/popup.c
@@ -22,6 +22,15 @@ static void popup_window_init ( PopupWindow *self )
 {
 }
 
+// DYNAMIC ISLAND PATCH: Spring animation callback
+static gboolean popup_spring_timeout(gpointer data)
+{
+    GtkWidget *widget = GTK_WIDGET(data);
+    GtkStyleContext *context = gtk_widget_get_style_context(widget);
+    gtk_style_context_remove_class(context, "popup-animating-in");
+    return FALSE;
+}
+
 static void popup_set_property ( GObject *self, guint prop,
     const GValue *value, GParamSpec *param )
 {
@@ -216,6 +225,12 @@ void popup_show ( GtkWidget *parent, GtkWidget *popup, GdkSeat *seat )
     g_object_set_data (G_OBJECT (gpopup), "gdk-attached-grab-window", NULL);
     gtk_grab_add(child);
   }
+
+  // DYNAMIC ISLAND PATCH: Spring animation for popups
+  GtkStyleContext *context = gtk_widget_get_style_context(popup);
+  gtk_style_context_add_class(context, "popup-animating-in");
+  // Give GTK enough time to render the first frame with the 'animating-in' class
+  g_timeout_add(16, (GSourceFunc)popup_spring_timeout, popup);
 }
 
