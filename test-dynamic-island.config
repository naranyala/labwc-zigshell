# Dynamic Island / Spring Popup Test Config
# This config tests the custom patches we wrote.

theme = "Adwaita"

# Ensure halign is applied to the inner ebox, while the GTK Window spans the screen transparently.
layout "sfwbar" {
  layer = "top"
  halign = "center"
  valign = "start"

  # Inner bar element
  button "Dynamic Island" {
    action = "PopUp 'test_popup'"
    style = "island_button"
  }
}

layout "test_popup" {
  button "Item 1" { style = "popup_item" }
  button "Item 2" { style = "popup_item" }
  button "Item 3" { style = "popup_item" }
}

CSS
/* We can now style #ebox directly for the floating island effect! */
#ebox {
  background-color: rgba(30, 30, 30, 0.9);
  border-radius: 20px;
  margin-top: 10px;
  padding: 5px 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
}

button#island_button {
  background: none;
  border: none;
  color: white;
  font-weight: bold;
  font-size: 14px;
}

/* 
 * POPUP SPRING ANIMATIONS 
 * The .popup-animating-in class is temporarily applied by our C patch. 
 * We set the "hidden" state here, and the transition handles it springing in 
 * when the class is automatically removed after 16ms!
 */
window#test_popup {
  background-color: rgba(40, 40, 40, 0.95);
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  padding: 10px;
  margin-top: 10px; /* target margin */
  opacity: 1; /* target opacity */
  
  /* The bouncy cubic-bezier! */
  transition: all 400ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

window#test_popup.popup-animating-in {
  margin-top: -30px; /* Start higher up */
  opacity: 0;        /* Start invisible */
  transition: none;  /* Don't animate on hide */
}

button#popup_item {
  background: none;
  border: none;
  color: white;
  min-width: 150px;
  padding: 5px;
}
button#popup_item:hover {
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 6px;
}
