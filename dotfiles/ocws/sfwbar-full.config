#Api2

# SFWBar — Single-bar mode (all-in-one top bar)
# Designed for use with crystal-dock or standalone.
# Edit user.config for personal changes — this file gets overwritten on update.
# env.config is generated by toggle-shell from OCWS_* env vars.

Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = $OCWSBarThickness

switcher { disable = true }

Function SfwbarInit() {}

# --- Env overrides (generated by toggle-shell) ---
include("env.config")

# ============================================================
# Core Layout Modes
# ============================================================
include("modes/statusbar.config")

# --- User Overlay Config ---
include("user.config")

# --- Theme CSS ---
include("css/theme.css")
include("css/tokens.css")
include("modes/css-glassmorphism.config")
include("modes/css-bars.config")
include("css/ocws.css")
