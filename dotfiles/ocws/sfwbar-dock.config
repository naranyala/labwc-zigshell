#Api2
# sfwbar-dock.config — Standalone dock experiment
# Test: sfwbar -c sfwbar-dock.config

Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "48px"

switcher { disable = true }

Function SfwbarInit() {}

bar {
  edge = "bottom"
  layer = "dock"
  exclusive_zone = -1
  monitor = "*"

  widget "dock"
}

include("widgets/core/dock-exp.widget")

include("css/tokens.css")
include("css/dock-exp.css")
