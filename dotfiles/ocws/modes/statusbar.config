#Api2
# modes/statusbar.config — Single status bar (for crystal-dock mode)
# Optimized for use with external crystal-dock at bottom

bar "statusbar:top" {
  edge = "top"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = $OCWSBarThickness

  # --- Left: Launcher + Workspaces ---
  widget "launcher.widget"
  widget "workspaces.widget"

  # --- Center: Clock (prominent) ---
  label { css = "* { -GtkWidget-hexpand: true; }" }
  widget "clock.widget"
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: System Status + Controls ---
  include("widget-sets/media.set")
  include("widget-sets/right-system.set")
  include("widgets/core/tray.widget")
  widget "ocws-control-center"
}
