#Api2
# modes/bottombar.config — Bottom bar with dock + taskbar
# Includes: dock apps, taskbar, show desktop, tray, clock

bar "bottombar:bottom" {
  edge = "bottom"
  layer = "top"
  mirror = "*"
  exclusive_zone = "auto"
  size = $OCWSBottomSize

  # --- Left: Dock Apps (inline) ---
  widget "dock"

  # --- Center: Taskbar ---
  taskbar {
    style = "taskbar"
    rows = 1
    icons = true
    labels = false
    tooltips = true
    icon_size = 28
    sort = false
    title_width = 20
    action[Drag] = Focus()
    action[RightClick] = Menu("winops")
    action[MiddleClick] = Close()
    css = "* { -GtkWidget-hexpand: true; -GtkWidget-halign: center; }"
  }

  # --- Spacer ---
  label { css = "* { -GtkWidget-hexpand: true; }" }

  # --- Right: Show Desktop + Tray + Clock ---
  widget "showdesktop"
  include("widgets/core/tray.widget")
  widget "clock"
}
