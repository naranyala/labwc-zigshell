#Api2

# ============================================================
# User Overlay Config — Personal Customizations
# ============================================================
# This file is NOT overwritten by install.sh.
# Edit freely — your changes survive updates.
#
# Loaded AFTER all platform configs, so anything here
# overrides the defaults.
#
# Available env vars (set before starting compositor):
#   OCWS_BAR_THICKNESS  — single-bar thickness (default: 34px)
#   OCWS_TOP_SIZE       — top bar height in doublepanel mode (default: 32)
#   OCWS_BOTTOM_SIZE    — bottom bar height in doublepanel mode (default: 32)
# ============================================================

# --- Change widget set for top bar (doublepanel mode) ---
# Options: full.set (default), standard.set, right-system.set,
#          system-metrics.set, status.set, media.set
# Or create your own .set file in widget-sets/
# bar "topbar:top" { include("widget-sets/standard.set") }

# --- Override terminal ---
# Exec("foot")  →  Exec("kitty")

# --- Custom dock apps ---
# Edit dock-apps.widget or swap to dock-exp:
# In ocws.config, change: widget "dock"  →  include("widgets/core/dock-exp.widget")

# --- Custom CSS ---
# #CSS
# button.module { min-height: 20px; }
