#Api2

# SFWBar — Dual Panel (Top Status Bar + Bottom Dock/Taskbar)
# Override bar sizes: env OCWS_TOP_SIZE (default: 32), OCWS_BOTTOM_SIZE (default: 32)
# Override dock type: env OCWS_DOCK (dock|dock-exp, default: dock)
# Edit user.config for personal changes — this file gets overwritten on update

Set ImagePath = "icons/misc:icons/weather"
Set ThicknessHint = "36px"

switcher { disable = false }

Function SfwbarInit() {}

# --- Env overrides ---
include("env.config")

# --- Plugin Autoloader ---
include("plugins.config")
include("sources/ocws-sysmon.source")

# ============================================================
# Core Layout Modes
# ============================================================
include("modes/topbar.config")
include("modes/bottombar.config")
include("modes/desktop.config")

# --- User Overlay Config ---
include("user.config")

# --- Theme CSS ---
include("css/theme.css")
include("css/tokens.css")
include("modes/css-glassmorphism.config")
include("modes/css-bars.config")
include("css/ocws.css")
