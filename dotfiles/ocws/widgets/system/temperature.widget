#Api2

# Temperature text widget — shows CPU temperature
export button "temperature" {
  interval = 3000
  style = If(XTemp > 75, "text_urgent", "text_metric")
  tooltip = "CPU Temperature: " + Str(XTemp, 0) + "°C"
  action = Exec("foot -e sensors")

  label {
    value = "󰏸 " + Str(XTemp, 0) + "°"
  }
}

